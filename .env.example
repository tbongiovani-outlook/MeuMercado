# Copie este arquivo para .env e preencha com os dados da sua aplicação do DevCenter.
# NUNCA versione o arquivo .env (ele está no .gitignore).

# Credenciais da aplicação criada em https://developers.mercadolivre.com.br/devcenter
MELI_CLIENT_ID=
MELI_CLIENT_SECRET=

# URL de redirecionamento (redirect_uri).
# Por padrão usamos a "página-ponte" HTTPS publicada no GitHub Pages, que devolve
# o código de autorização para o aplicativo local. É a MESMA URL para todos os
# usuários — basta cadastrá-la no DevCenter do seu app. Normalmente você NÃO
# precisa mudar isto.
MELI_REDIRECT_URI=https://tbongiovani-outlook.github.io/MeuMercado/callback.html

# Domínio de autorização por país (Brasil por padrão).
# Outros: .com.ar (Argentina), .com.mx (México), .cl (Chile), etc.
MELI_AUTH_DOMAIN=https://auth.mercadolivre.com.br
MELI_API_BASE=https://api.mercadolibre.com

# Chave usada para assinar a sessão. Gere uma aleatória, por exemplo:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
APP_SECRET_KEY=troque-por-uma-chave-aleatoria-segura

# Caminho do banco SQLite local
DATABASE_PATH=meu_mercado.db
